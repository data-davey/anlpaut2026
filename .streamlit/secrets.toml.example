# Streamlit secrets — fill in your values before deploying.
# Local: copy this file to .streamlit/secrets.toml and fill in your values.
# Streamlit Cloud: paste the contents into App Settings → Secrets.

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY = ""

# ── Optional (leave blank if not using org/project scoping) ───────────────────
OPENAI_ORG_ID = ""
OPENAI_PROJECT_ID = ""

# ── Model overrides (defaults shown) ─────────────────────────────────────────
SESSION8_MODEL = "gpt-4o-mini"
SESSION8_EMBEDDING_MODEL = "text-embedding-3-small"
